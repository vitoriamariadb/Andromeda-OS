#!/bin/bash

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

BLOCKED=0

if echo "$MSG" | grep -qiE "Co-Authored-By|co_authored|Paired-with|Assisted-by"; then
    echo "  [BLOQUEIO] Mensagem de commit contem atribuicao de co-autoria"
    echo "    Detectado em: $MSG_FILE"
    echo "    Remova qualquer Co-Authored-By, Paired-with ou Assisted-by"
    BLOCKED=1
fi

if echo "$MSG" | grep -qiE "claude|anthropic|openai|chatgpt|copilot|gemini|gpt-4|gpt-3"; then
    echo "  [BLOQUEIO] Mensagem de commit menciona ferramenta de IA"
    echo "    Detectado em: $MSG_FILE"
    echo "    Remova qualquer referencia a IA da mensagem"
    BLOCKED=1
fi

EMOJI_RE='[\x{1F600}-\x{1F64F}\x{1F300}-\x{1F5FF}\x{1F680}-\x{1F6FF}\x{2600}-\x{26FF}\x{2700}-\x{27BF}\x{1F900}-\x{1F9FF}\x{1FA00}-\x{1FA6F}\x{1FA70}-\x{1FAFF}]'
if echo "$MSG" | grep -qP "$EMOJI_RE"; then
    echo "  [BLOQUEIO] Mensagem de commit contem emojis"
    echo "    Detectado em: $MSG_FILE"
    echo "    Remova todos os emojis da mensagem"
    BLOCKED=1
fi

if [ $BLOCKED -gt 0 ]; then
    exit 1
fi

exit 0
