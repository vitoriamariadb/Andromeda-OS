# OpenRGB udev rules - acesso a SMBus/i2c/hidraw para controle RGB
# Fonte-de-verdade: ~/.config/zsh/scripts/60-openrgb.rules
# Destino: /etc/udev/rules.d/60-openrgb.rules (mantido pelo ritual-aurora-self-heal)

# i2c devices
KERNEL=="i2c-[0-9]*", MODE="0666"
SUBSYSTEM=="i2c-dev", MODE="0666"

# hidraw para gamepads e periféricos
KERNEL=="hidraw*", MODE="0666"

# NVIDIA i2c (GPU)
KERNEL=="nvidia_*", MODE="0666"
