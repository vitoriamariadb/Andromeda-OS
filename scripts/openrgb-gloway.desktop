[Desktop Entry]
Type=Application
Name=OpenRGB Gloway profile loader
Comment=Aplica profile salvo pra parar piscar da Gloway (camada user — system service já aplica antes)
Exec=/home/vitoriamaria/.local/bin/openrgb --profile gloway-roxo --startminimized
X-GNOME-Autostart-enabled=true
NoDisplay=true
Terminal=false
